# Email — Gmail App Password (NOT main password); 2FA must be on
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_16_char_app_password
EMAIL_TO=you@gmail.com

# Optional cloud fallback (free tier)
GROQ_API_KEY=

# NVD API key — optional but recommended (5→50 req/30s)
NVD_API_KEY=

# Paths
OBSIDIAN_VAULT_PATH=/Users/shoeb/Obsidian/Vault
OBSIDIAN_CTI_FOLDER=CTI/Daily

# Git — SSH only. `ssh -T git@github.com` must succeed.
GIT_REMOTE_SSH=git@github.com:shoeb/cti-briefing.git

# Immediate-alert channel
ALERT_WEBHOOK_URL=
ALERT_EMAIL=

# Defensive
TZ=America/Chicago
